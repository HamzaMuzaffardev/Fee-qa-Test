{% comment %}
  Custom Measurements Form
  Renders a measurement form for custom-fit products
  
  Usage: {% render 'custom-measurements', product: product %}
  
  Requires: 
  - product.metafields.custom.is_custom = true (to show the form)
  - assets/custom-measurements.css
  - assets/custom-measurements.js
{% endcomment %}

{{ 'custom-measurements.css' | asset_url | stylesheet_tag }}
<script src="{{ 'custom-measurements.js' | asset_url }}" defer></script>

<div class="custom-measurements-wrapper" data-measurements-required="true">
    <div class="measurements-header">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 3H3v18h18V3z"></path>
        <path d="M9 3v18"></path>
        <path d="M3 9h6"></path>
        <path d="M3 15h6"></path>
      </svg>
      <h4 class="measurements-title">{{ 'products.product.custom_measurements.title' | t | default: 'Your Custom Measurements' }}</h4>
    </div>
    
    {% comment %} <p class="measurements-subtitle">
      {{ 'products.product.custom_measurements.subtitle' | t | default: 'Please provide your body measurements for a perfect custom fit. All measurements should be in centimeters (cm).' }}
    </p> {% endcomment %}
    
    <div class="measurements-required-note">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>
      <span>
        {{ 'products.product.custom_measurements.required_note' | t | default: 'All measurements must be provided in inches (in). Fields marked with * are required.' }}
      </span>
    </div>

    <table class="abaya-measurements">
      <thead>
        <tr>
          <th>{{ 'products.product.custom_measurements.measurement' | t | default: 'Measurement' }}</th>
          <th>{{ 'products.product.custom_measurements.your_value' | t | default: 'Your Value (in)' }}</th>
        </tr>
      </thead>
      <tbody>
        {% comment %}
          NEW MEASUREMENT TABLE (INCHES)

          Two sizing tracks are supported:
          - Standard sizing (S / M / L, etc.): customer must provide a custom Length (in).
          - Custom sizing (Custom size option): customer must provide Shoulder, Bust, Armhole,
            Sleeve Length and Length (all in).

          The JS (assets/custom-measurements.js) uses the data-measurement-role attributes below
          to decide which fields are required and when to hide/show rows.
        {% endcomment %}

        {% comment %} 1. Shoulder - required ONLY for Custom sizing {% endcomment %}
        <tr data-measurement-role="shoulder">
          <td>
            {{ 'products.product.custom_measurements.shoulder' | t | default: 'Shoulder' }}
            <span class="required-indicator">*</span>
          </td>
          <td>
            <input
              type="text"
              inputmode="decimal"
              name="properties[Shoulder (in)]"
              data-measurement-role="shoulder"
              placeholder="{{ 'products.product.custom_measurements.placeholder_shoulder' | t | default: 'e.g. 15.5' }}"
            >
          </td>
        </tr>

        {% comment %} 2. Bust - required ONLY for Custom sizing {% endcomment %}
        <tr data-measurement-role="bust">
          <td>
            {{ 'products.product.custom_measurements.bust' | t | default: 'Bust' }}
            <span class="required-indicator">*</span>
          </td>
          <td>
            <input
              type="text"
              inputmode="decimal"
              name="properties[Bust (in)]"
              data-measurement-role="bust"
              placeholder="{{ 'products.product.custom_measurements.placeholder_bust' | t | default: 'e.g. 38' }}"
            >
          </td>
        </tr>

        {% comment %} 3. Armhole - required ONLY for Custom sizing {% endcomment %}
        <tr data-measurement-role="armhole">
          <td>
            {{ 'products.product.custom_measurements.armhole' | t | default: 'Armhole' }}
            <span class="required-indicator">*</span>
          </td>
          <td>
            <input
              type="text"
              inputmode="decimal"
              name="properties[Armhole (in)]"
              data-measurement-role="armhole"
              placeholder="{{ 'products.product.custom_measurements.placeholder_armhole' | t | default: 'e.g. 18' }}"
            >
          </td>
        </tr>

        {% comment %} 4. Sleeve Length - required ONLY for Custom sizing {% endcomment %}
        <tr data-measurement-role="sleeve_length">
          <td>
            {{ 'products.product.custom_measurements.sleeve' | t | default: 'Sleeve Length' }}
            <span class="required-indicator">*</span>
          </td>
          <td>
            <input
              type="text"
              inputmode="decimal"
              name="properties[Sleeve Length (in)]"
              data-measurement-role="sleeve_length"
              placeholder="{{ 'products.product.custom_measurements.placeholder_sleeve' | t | default: 'e.g. 23' }}"
            >
          </td>
        </tr>

        {% comment %} 5. Length - REQUIRED for BOTH Standard and Custom sizing {% endcomment %}
        <tr data-measurement-role="length">
          <td>
            {{ 'products.product.custom_measurements.length' | t | default: 'Length' }}
            <span class="required-indicator">*</span>
          </td>
          <td>
            <input
              type="text"
              inputmode="decimal"
              name="properties[Custom Length (in)]"
              data-measurement-role="length"
              required
              placeholder="{{ 'products.product.custom_measurements.placeholder_length' | t | default: 'e.g. 54' }}"
            >
          </td>
        </tr>
      </tbody>
    </table>
    
    <div class="measurements-error">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="15" y1="9" x2="9" y2="15"></line>
        <line x1="9" y1="9" x2="15" y2="15"></line>
      </svg>
      <span>{{ 'products.product.custom_measurements.error_message' | t | default: 'Please fill in all required measurements' }}</span>
    </div>
  </div>
</div>

